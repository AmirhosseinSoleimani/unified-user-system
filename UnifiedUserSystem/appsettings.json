{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Ssl Mode=Disable"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_ENV_OR_USER_SECRET",
